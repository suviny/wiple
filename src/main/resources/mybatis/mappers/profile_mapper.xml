<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.suviny.wiple.domain.profile.mapper.ProfileMapper">

    <!-- 가입된 사용자의 식별 번호를 토대로 프로필 정보를 생성한다. -->
    <insert id="insertProfile" parameterType="Long">
        INSERT INTO profiles (
            user_id,
            updated_at
        ) VALUES (
            #{userId},
            NOW()
        )
    </insert>
</mapper>